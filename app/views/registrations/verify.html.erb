<div class="container-sm flex items-center justify-center min-h-screen">
  <div class="card w-full max-w-md">
    <div class="card-body">
      <div class="text-center mb-8">
        <div class="text-5xl mb-4">📬</div>
        <h1 class="text-3xl font-bold text-primary">验证邮箱</h1>
        <p class="text-muted mt-3 text-sm">
          验证码已发送到您的邮箱<br>
          <% if @pending_user %>
            <strong class="text-foreground"><%= @pending_user.email %></strong><br>
          <% end %>
          请在 15 分钟内完成验证
        </p>
      </div>

      <%= form_with url: confirm_sign_up_path, method: :post, class: "space-y-6" do |form| %>
        <div>
          <%= label_tag :code, "验证码", class: "form-label" %>
          <%= text_field_tag :code, nil,
              required: true,
              autofocus: true,
              autocomplete: "one-time-code",
              inputmode: "numeric",
              pattern: "[0-9]{6}",
              maxlength: 6,
              placeholder: "请输入 6 位验证码",
              class: "form-input text-center text-2xl tracking-widest font-mono" %>
        </div>

        <div class="pt-2">
          <%= submit_tag "验证并登录", class: "btn-primary w-full btn-lg" %>
        </div>
      <% end %>

      <div class="mt-6 text-center text-sm text-muted">
        没有收到验证码？
        <%= button_to "重新发送", resend_code_sign_up_path, method: :post,
            class: "text-primary hover:underline font-medium bg-transparent border-0 cursor-pointer p-0",
            data: { turbo: false } %>
      </div>

      <div class="mt-4 text-center text-sm text-muted">
        <%= link_to "← 返回注册", sign_up_path, class: "text-muted hover:text-foreground" %>
      </div>
    </div>
  </div>
</div>
